{
  "name": "iq-remote-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Web UI to edit Firebase Remote Config for brain-training (native fullscreen ad v1)",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"yarn dev:server\" \"yarn dev:web\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite web",
    "build:web": "vite build web",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "antd": "^5.22.0",
    "express": "^4.21.0",
    "firebase-admin": "^13.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
